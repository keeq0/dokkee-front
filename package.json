{
  "name": "docscheck",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "serve": "vue-cli-service serve",
    "build": "vue-cli-service build",
    "lint": "vue-cli-service lint --no-fix",
    "lint:fix": "vue-cli-service lint",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "axios": "^1.8.4",
    "core-js": "^3.8.3",
    "gsap": "^3.13.0",
    "html2canvas": "^1.4.1",
    "html2pdf.js": "^0.10.3",
    "jspdf": "^3.0.1",
    "mammoth": "^1.9.0",
    "openai": "^4.91.1",
    "pdfjs-dist": "^5.0.375",
    "pinia": "^2.2.6",
    "vue": "^3.2.13",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@babel/core": "^7.12.16",
    "@babel/eslint-parser": "^7.12.16",
    "@babel/plugin-transform-class-static-block": "^7.26.0",
    "@babel/plugin-transform-private-methods": "^7.25.9",
    "@pinia/testing": "^0.1.7",
    "@playwright/test": "1.49.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vitest/coverage-v8": "^2.1.9",
    "@vue/cli-plugin-babel": "~5.0.0",
    "@vue/cli-plugin-eslint": "~5.0.0",
    "@vue/cli-service": "~5.0.0",
    "@vue/test-utils": "^2.4.6",
    "dotenv-webpack": "^8.1.0",
    "eslint": "^7.32.0",
    "eslint-plugin-vue": "^8.0.3",
    "jsdom": "^25.0.1",
    "vitest": "^2.1.8"
  },
  "eslintConfig": {
    "root": true,
    "env": {
      "node": true
    },
    "extends": [
      "plugin:vue/vue3-essential",
      "eslint:recommended"
    ],
    "parserOptions": {
      "parser": "@babel/eslint-parser"
    },
    "rules": {},
    "overrides": [
      {
        "files": [
          "tests/unit/**/*.{js,spec.js}",
          "vitest.config.js"
        ],
        "env": {
          "node": true
        },
        "globals": {
          "describe": "readonly",
          "it": "readonly",
          "expect": "readonly",
          "beforeEach": "readonly",
          "afterEach": "readonly",
          "beforeAll": "readonly",
          "afterAll": "readonly",
          "vi": "readonly"
        }
      },
      {
        "files": [
          "tests/e2e/**/*.{js,spec.js}",
          "playwright.config.js"
        ],
        "env": {
          "node": true
        }
      }
    ]
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead",
    "not ie 11"
  ]
}
