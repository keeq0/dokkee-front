# Полезно при работе с volume в Docker (Linux/Mac/Windows): принудительно использовать polling
# для отслеживания изменений файлов webpack-dev-server.
CHOKIDAR_USEPOLLING=true

# Хост и порт dev-сервера внутри контейнера.
HOST=0.0.0.0
PORT=8080

# Базовый URL для Playwright (используется только при локальном запуске вне Docker).
# В Docker значение проставляется в docker-compose.yml (http://frontend:8080).
BASE_URL=http://localhost:8085

# Ключ DeepSeek API. Получить в личном кабинете https://platform.deepseek.com/
# Скопируйте этот файл в .env и проставьте реальный ключ (в репозиторий не коммитится).
VUE_APP_DEEPSEEK_KEY=sk-replace-with-your-key
